                        <p className="text-zinc-400 text-lg leading-relaxed max-w-lg mx-auto md:mx-0">{t.home.templatesDesc}</p>
                        <div className="flex flex-col sm:flex-row gap-4 justify-center md:justify-start pt-4">
                            <button onClick={() => goToPage('templates')} className="px-8 py-4 bg-white text-black rounded-2xl font-black text-lg hover:scale-105 transition-transform shadow-xl shadow-white/10 flex items-center justify-center gap-2">{t.home.templatesBtn} <Icon name="layout-template" size={20} /></button>
                            <div className="flex items-center justify-center gap-2 text-zinc-500 text-sm px-4"><Icon name="check" size={16} className="text-green-500" /> {t.home.templatesNote}</div>
                        </div>
                    </div>
                    <div className="w-full md:w-2/5 relative home-perspective">
                        <div className="relative z-20 bg-zinc-900 rounded-2xl border border-white/10 p-2 template-card-3d shadow-2xl">
                            <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=600" className="rounded-xl w-full h-auto opacity-90" />
                        </div>
                    </div>
                </div>
            </motion.div>
        </div>
    );
};

// راه‌اندازی صفحه
renderPage('home', HomePage);

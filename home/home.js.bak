                <div className="flex flex-col md:flex-row justify-between items-end mb-10 gap-4">
                    <div>
                        <div className="text-accent font-bold mb-2 tracking-widest text-sm">PORTFOLIO</div>
                        <h2 className="text-4xl md:text-6xl font-black text-primary">{t.home.portfolioTitle}</h2>
                    </div>
                    <button onClick={() => goToPage('portfolio')} className="hidden md:flex items-center gap-2 px-6 py-3 rounded-full border border-border hover:bg-surface transition-all group">{t.home.portfolioBtn} <Icon name="arrow-left" className="group-hover:-translate-x-1 transition-transform" size={18} /></button>
                </div>
                <div className="grid grid-cols-1 md:grid-cols-2 gap-8 home-perspective">
                    <motion.div whileHover={{ y: -10, scale: 1.02 }} transition={{ type: "spring", stiffness: 300 }} onClick={() => goToPage('portfolio')} className="group relative h-[400px] md:h-[500px] rounded-[2rem] overflow-hidden cursor-pointer border border-white/5 shadow-2xl">
                        <img src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=800" className="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
                        <div className="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent opacity-90" />
                        <div className="absolute top-6 right-6 bg-white/10 backdrop-blur-md px-4 py-2 rounded-full text-xs font-bold text-white border border-white/10">Real Estate</div>
                        <div className="absolute bottom-0 left-0 p-10 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
